# Copy this file to .env and fill in the keys for your chosen provider(s).
# You only need keys for the providers you configure in config.py.

# LLM providers — add keys for the one(s) you want to use
TOGETHER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional — enables the web search tool (Tavily)
TAVILY_API_KEY=

# Optional — LangSmith tracing: LANGCHAIN_TRACING_V2=true and LANGSMITH_API_KEY=...
# Runs go to project boardgame_agent unless you set LANGCHAIN_PROJECT in .env
